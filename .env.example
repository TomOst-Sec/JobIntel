# ── Job Data APIs ─────────────────────────────────────────────
# Required: RapidAPI key for JSearch + LinkedIn Data APIs
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: Claude AI for market analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate-a-strong-random-secret-here
ENCRYPTION_KEY=generate-a-32-byte-hex-key-here

# ── OAuth (optional) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Payments (optional) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Email (optional) ─────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# ── Additional Scrapers (optional — skipped if empty) ────────
THEMUSE_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# ── OpenRouter (optional — free models) ──────────────────────
OPENROUTER_API_KEY=

# ── SMS (optional) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── App ──────────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000
